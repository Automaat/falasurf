---
import { getLangFromUrl, useTranslations, getLocalePath } from "../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const altLang = lang === "pl" ? "en" : "pl";
const altFlag = lang === "pl" ? "/images/flags/gb.svg" : "/images/flags/pl.svg";
const altLabel = lang === "pl" ? "English" : "Polski";

const contactAnchor = lang === "pl" ? "#kontakt" : "#contact";

const navItems = [
  { href: "#o-nas", label: t("nav.about") },
  { href: "#windsurfing", label: t("nav.windsurfing") },
  { href: "#surfing", label: t("nav.surfing") },
  { href: "#lokalizacja", label: t("nav.location") },
  { href: "#cennik", label: t("nav.pricing") },
  { href: contactAnchor, label: t("nav.contact") },
];
---

<nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 flex items-center justify-between h-16 md:h-20">
    <a href={getLocalePath(lang)} class="flex-shrink-0">
      <img
        src="/images/logo.png"
        alt="Fala Wind & Surf School"
        class="h-10 md:h-12 transition-all duration-300 drop-shadow-[0_0_8px_rgba(255,255,255,0.8)]"
        id="nav-logo"
      />
    </a>

    <div class="hidden lg:flex items-center gap-8">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="nav-link text-sm font-semibold uppercase tracking-wider text-white/90 hover:text-white transition-colors"
        >
          {item.label}
        </a>
      ))}
    </div>

    <div class="hidden lg:flex items-center gap-5">
      <a href="tel:+34612490732" class="nav-phone text-sm font-semibold text-white/90 hover:text-white transition-colors">
        +34 612 49 07 32
      </a>
      <a
        href={getLocalePath(altLang)}
        class="flex items-center gap-1.5 text-sm"
        aria-label={altLabel}
      >
        <img src={altFlag} alt={altLabel} class="h-6 w-6 rounded-full object-cover ring-2 ring-white/30 hover:ring-white/60 transition-all" />
      </a>
    </div>

    <button
      id="nav-toggle"
      class="lg:hidden flex flex-col gap-[5px] cursor-pointer p-2"
      aria-label="Toggle menu"
      type="button"
    >
      <span class="nav-bar block w-6 h-[2px] bg-white transition-all duration-300 origin-center"></span>
      <span class="nav-bar block w-6 h-[2px] bg-white transition-all duration-300"></span>
      <span class="nav-bar block w-6 h-[2px] bg-white transition-all duration-300 origin-center"></span>
    </button>
  </div>

  <div id="mobile-menu" class="hidden lg:hidden flex-col bg-white shadow-2xl border-t border-gray-100">
    {navItems.map((item) => (
      <a
        href={item.href}
        class="mobile-link px-6 py-4 text-gray-text hover:bg-sand hover:text-navy transition-colors font-medium uppercase tracking-wide text-sm"
      >
        {item.label}
      </a>
    ))}
    <div class="px-6 py-4 flex items-center justify-between border-t border-gray-100">
      <a href="tel:+34612490732" class="text-sm font-semibold text-navy">
        +34 612 49 07 32
      </a>
      <a href={getLocalePath(altLang)} class="flex items-center gap-2">
        <img src={altFlag} alt={altLabel} class="h-6 w-6 rounded-full object-cover ring-2 ring-navy/20" />
        <span class="text-sm font-medium text-gray-text">{altLabel}</span>
      </a>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById("main-nav")!;
  const logo = document.getElementById("nav-logo")!;
  const toggle = document.getElementById("nav-toggle")!;
  const menu = document.getElementById("mobile-menu")!;
  const bars = toggle.querySelectorAll(".nav-bar");
  let menuOpen = false;

  function updateNav() {
    const scrolled = window.scrollY > 80;
    if (scrolled || menuOpen) {
      nav.classList.add("bg-white", "shadow-md");
      nav.classList.remove("bg-transparent");
      logo.classList.remove("drop-shadow-[0_0_8px_rgba(255,255,255,0.8)]");
      document.querySelectorAll<HTMLElement>(".nav-link").forEach(l => {
        l.classList.remove("text-white/90", "hover:text-white");
        l.classList.add("text-gray-text", "hover:text-navy");
      });
      const phone = document.querySelector<HTMLElement>(".nav-phone");
      if (phone) {
        phone.classList.remove("text-white/90", "hover:text-white");
        phone.classList.add("text-navy");
      }
      bars.forEach(b => {
        b.classList.remove("bg-white");
        b.classList.add("bg-navy");
      });
    } else {
      nav.classList.remove("bg-white", "shadow-md");
      nav.classList.add("bg-transparent");
      logo.classList.add("drop-shadow-[0_0_8px_rgba(255,255,255,0.8)]");
      document.querySelectorAll<HTMLElement>(".nav-link").forEach(l => {
        l.classList.add("text-white/90", "hover:text-white");
        l.classList.remove("text-gray-text", "hover:text-navy");
      });
      const phone = document.querySelector<HTMLElement>(".nav-phone");
      if (phone) {
        phone.classList.add("text-white/90", "hover:text-white");
        phone.classList.remove("text-navy");
      }
      bars.forEach(b => {
        b.classList.add("bg-white");
        b.classList.remove("bg-navy");
      });
    }
  }

  window.addEventListener("scroll", updateNav, { passive: true });
  updateNav();

  toggle.addEventListener("click", () => {
    menuOpen = !menuOpen;
    menu.classList.toggle("hidden");
    menu.classList.toggle("flex");
    if (menuOpen) {
      bars[0].classList.add("translate-y-[7px]", "rotate-45");
      bars[1].classList.add("opacity-0");
      bars[2].classList.add("-translate-y-[7px]", "-rotate-45");
    } else {
      bars[0].classList.remove("translate-y-[7px]", "rotate-45");
      bars[1].classList.remove("opacity-0");
      bars[2].classList.remove("-translate-y-[7px]", "-rotate-45");
    }
    updateNav();
  });

  document.querySelectorAll(".mobile-link").forEach(link => {
    link.addEventListener("click", () => {
      menuOpen = false;
      menu.classList.add("hidden");
      menu.classList.remove("flex");
      bars[0].classList.remove("translate-y-[7px]", "rotate-45");
      bars[1].classList.remove("opacity-0");
      bars[2].classList.remove("-translate-y-[7px]", "-rotate-45");
      updateNav();
    });
  });
</script>
