---
interface Testimonial {
  text: string;
  author: string;
  origin: string;
}

interface Props {
  id: string;
  title: string;
  testimonials: Testimonial[];
}

const { id, title, testimonials } = Astro.props;
---

<section id={id} class="py-20 md:py-28 bg-white scroll-mt-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <h2 class="text-3xl md:text-4xl font-bold text-black mb-4 text-center">{title}</h2>
    <div class="w-12 h-1 bg-navy rounded-full mx-auto mb-14"></div>

    <div class="grid md:grid-cols-3 gap-8">
      {testimonials.map((t) => (
        <div class="bg-sand rounded-2xl p-8 flex flex-col">
          {/* Stars */}
          <div class="flex gap-1 mb-4">
            {[...Array(5)].map(() => (
              <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <blockquote class="text-base leading-relaxed flex-1 mb-6">
            &ldquo;{t.text}&rdquo;
          </blockquote>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-navy/10 flex items-center justify-center text-navy font-bold text-sm">
              {t.author.split(" ").map(n => n[0]).join("")}
            </div>
            <div>
              <div class="font-semibold text-black text-sm">{t.author}</div>
              <div class="text-xs text-gray-text/70">{t.origin}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
