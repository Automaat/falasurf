---
interface Props {
  id: string;
  title: string;
  phone: string;
  whatsappText: string;
  facebookUrl: string;
  instagramUrl: string;
  mapEmbedUrl: string;
}

const { id, title, phone, whatsappText, facebookUrl, instagramUrl, mapEmbedUrl } = Astro.props;
const whatsappUrl = `https://api.whatsapp.com/send?phone=${phone.replace(/[^0-9]/g, "")}`;
---

<section id={id} class="py-20 md:py-28 scroll-mt-20 bg-white">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <h2 class="text-3xl md:text-4xl font-bold text-black mb-4 text-center">{title}</h2>
    <div class="w-12 h-1 bg-navy rounded-full mx-auto mb-14"></div>

    {/* Contact cards row */}
    <div class="grid sm:grid-cols-3 gap-6 mb-14">
      {/* Phone card */}
      <a
        href={`tel:${phone}`}
        class="group flex flex-col items-center text-center p-8 rounded-2xl bg-sand hover:bg-navy transition-all duration-300"
      >
        <div class="w-16 h-16 rounded-full bg-navy/10 group-hover:bg-white/20 flex items-center justify-center mb-5 transition-colors">
          <svg class="w-7 h-7 text-navy group-hover:text-white transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
        </div>
        <span class="text-sm font-semibold uppercase tracking-wider text-navy/60 group-hover:text-white/70 mb-2 transition-colors">
          {title === "Kontakt" ? "Zadzwoń" : "Call us"}
        </span>
        <span class="text-lg font-bold text-navy group-hover:text-white transition-colors">
          {phone}
        </span>
      </a>

      {/* WhatsApp card */}
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex flex-col items-center text-center p-8 rounded-2xl bg-sand hover:bg-[#25D366] transition-all duration-300"
      >
        <div class="w-16 h-16 rounded-full bg-[#25D366]/10 group-hover:bg-white/20 flex items-center justify-center mb-5 transition-colors">
          <svg class="w-7 h-7 text-[#25D366] group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
          </svg>
        </div>
        <span class="text-sm font-semibold uppercase tracking-wider text-navy/60 group-hover:text-white/70 mb-2 transition-colors">
          WhatsApp
        </span>
        <span class="text-lg font-bold text-black group-hover:text-white transition-colors">
          {whatsappText}
        </span>
      </a>

      {/* Social card */}
      <div class="flex flex-col items-center text-center p-8 rounded-2xl bg-sand">
        <div class="w-16 h-16 rounded-full bg-navy/10 flex items-center justify-center mb-5">
          <svg class="w-7 h-7 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" />
          </svg>
        </div>
        <span class="text-sm font-semibold uppercase tracking-wider text-navy/60 mb-4">
          Social media
        </span>
        <div class="flex gap-4">
          <a
            href={facebookUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="w-12 h-12 rounded-full bg-white shadow-sm flex items-center justify-center text-navy hover:bg-navy hover:text-white hover:shadow-md transition-all duration-200"
            aria-label="Facebook"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
            </svg>
          </a>
          <a
            href={instagramUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="w-12 h-12 rounded-full bg-white shadow-sm flex items-center justify-center text-navy hover:bg-navy hover:text-white hover:shadow-md transition-all duration-200"
            aria-label="Instagram"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12s.015 3.667.072 4.947c.06 1.277.261 2.148.558 2.913.306.788.717 1.459 1.384 2.126.667.666 1.336 1.079 2.126 1.384.766.296 1.636.499 2.913.558C8.333 23.988 8.74 24 12 24s3.667-.015 4.947-.072c1.277-.06 2.148-.262 2.913-.558.788-.306 1.459-.718 2.126-1.384.666-.667 1.079-1.335 1.384-2.126.296-.765.499-1.636.558-2.913.06-1.28.072-1.687.072-4.947s-.015-3.667-.072-4.947c-.06-1.277-.262-2.149-.558-2.913-.306-.789-.718-1.459-1.384-2.126C21.319 1.347 20.651.935 19.86.63c-.765-.297-1.636-.499-2.913-.558C15.667.012 15.26 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 1.17.055 1.805.249 2.227.415.562.217.96.477 1.382.896.419.42.679.819.896 1.381.164.422.36 1.057.413 2.227.057 1.266.07 1.646.07 4.85s-.015 3.585-.074 4.85c-.061 1.17-.256 1.805-.421 2.227-.224.562-.479.96-.899 1.382-.419.419-.824.679-1.38.896-.42.164-1.065.36-2.235.413-1.274.057-1.649.07-4.859.07-3.211 0-3.586-.015-4.859-.074-1.171-.061-1.816-.256-2.236-.421-.569-.224-.96-.479-1.379-.899-.421-.419-.69-.824-.9-1.38-.165-.42-.359-1.065-.42-2.235-.045-1.26-.061-1.649-.061-4.844 0-3.196.016-3.586.061-4.861.061-1.17.255-1.814.42-2.234.21-.57.479-.96.9-1.381.419-.419.81-.689 1.379-.898.42-.166 1.051-.361 2.221-.421 1.275-.045 1.65-.06 4.859-.06l.045.03zm0 3.678a6.162 6.162 0 100 12.324 6.162 6.162 0 100-12.324zM12 16c-2.21 0-4-1.79-4-4s1.79-4 4-4 4 1.79 4 4-1.79 4-4 4zm7.846-10.405a1.441 1.441 0 11-2.882 0 1.441 1.441 0 012.882 0z" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    {/* Full-width map */}
    <div class="rounded-2xl overflow-hidden shadow-lg h-80 md:h-[420px]">
      <iframe
        src={mapEmbedUrl}
        width="100%"
        height="100%"
        style="border:0;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Fala Wind & Surf School location"
      ></iframe>
    </div>
  </div>
</section>
