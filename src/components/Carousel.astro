---
interface Props {
  images: { src: string; alt: string }[];
}

const { images } = Astro.props;
const id = `carousel-${Math.random().toString(36).slice(2, 8)}`;
const total = images.length;
---

<div class="relative group" data-carousel-root={id} role="group" aria-roledescription="carousel" aria-label="Image gallery">
  {/* Slides */}
  <div
    id={id}
    class="flex gap-5 overflow-x-auto snap-x snap-mandatory scroll-smooth scrollbar-hide rounded-2xl"
    aria-live="polite"
  >
    {images.map((img, i) => (
      <div class="snap-center shrink-0 w-[90%] sm:w-[75%] md:w-[65%]" role="group" aria-roledescription="slide" aria-label={`${i + 1} of ${total}`}>
        <img
          src={img.src}
          alt={img.alt}
          loading="lazy"
          class="w-full h-72 sm:h-80 md:h-96 object-cover rounded-2xl shadow-lg"
        />
      </div>
    ))}
  </div>

  {/* Prev/Next arrows */}
  {images.length > 1 && (
    <>
      <button
        data-dir="prev"
        data-target={id}
        class="carousel-arrow absolute left-2 top-1/2 -translate-y-1/2 w-10 h-10 bg-white/90 hover:bg-white rounded-full shadow-lg flex items-center justify-center opacity-0 group-hover:opacity-100 focus-visible:opacity-100 transition-opacity cursor-pointer"
        aria-label="Previous"
      >
        <svg class="w-5 h-5 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <button
        data-dir="next"
        data-target={id}
        class="carousel-arrow absolute right-2 top-1/2 -translate-y-1/2 w-10 h-10 bg-white/90 hover:bg-white rounded-full shadow-lg flex items-center justify-center opacity-0 group-hover:opacity-100 focus-visible:opacity-100 transition-opacity cursor-pointer"
        aria-label="Next"
      >
        <svg class="w-5 h-5 text-navy" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </>
  )}

  {/* Dots */}
  {images.length > 1 && (
    <div class="flex justify-center gap-2 mt-5">
      {images.map((_, i) => (
        <button
          data-carousel-dot={id}
          data-index={i}
          class="w-11 h-11 flex items-center justify-center cursor-pointer"
          aria-label={`Slide ${i + 1}`}
          aria-current={i === 0 ? "true" : undefined}
        >
          <span
            aria-hidden="true"
            class:list={[
              "block w-2.5 h-2.5 rounded-full transition-all duration-300",
              i === 0 ? "bg-navy w-6" : "bg-navy/25 hover:bg-navy/50",
            ]}
          />
        </button>
      ))}
    </div>
  )}
</div>

<script>
  document.querySelectorAll<HTMLElement>("[data-carousel-root]").forEach(root => {
    const id = root.dataset.carouselRoot!;
    const carousel = document.getElementById(id)!;
    const dots = root.querySelectorAll<HTMLButtonElement>(`[data-carousel-dot="${id}"]`);
    const slides = carousel.children;

    function updateDots() {
      const scrollLeft = carousel.scrollLeft;
      const slideWidth = (slides[0] as HTMLElement).offsetWidth;
      const gap = 20;
      const active = Math.round(scrollLeft / (slideWidth + gap));
      dots.forEach((dot, i) => {
        const span = dot.querySelector("span")!;
        if (i === active) {
          span.classList.add("bg-navy", "w-6");
          span.classList.remove("bg-navy/25");
          dot.setAttribute("aria-current", "true");
        } else {
          span.classList.remove("bg-navy", "w-6");
          span.classList.add("bg-navy/25");
          dot.removeAttribute("aria-current");
        }
      });
    }

    carousel.addEventListener("scroll", updateDots, { passive: true });

    dots.forEach(dot => {
      dot.addEventListener("click", () => {
        const index = Number(dot.dataset.index);
        const slide = slides[index] as HTMLElement;
        carousel.scrollTo({ left: slide.offsetLeft - carousel.offsetLeft, behavior: "smooth" });
      });
    });

    root.querySelectorAll<HTMLButtonElement>(".carousel-arrow").forEach(btn => {
      btn.addEventListener("click", () => {
        const dir = btn.dataset.dir;
        const slideWidth = (slides[0] as HTMLElement).offsetWidth + 20;
        carousel.scrollBy({ left: dir === "next" ? slideWidth : -slideWidth, behavior: "smooth" });
      });
    });

    root.addEventListener("keydown", (e: KeyboardEvent) => {
      if (e.key === "ArrowLeft" || e.key === "ArrowRight") {
        e.preventDefault();
        const slideWidth = (slides[0] as HTMLElement).offsetWidth + 20;
        carousel.scrollBy({ left: e.key === "ArrowRight" ? slideWidth : -slideWidth, behavior: "smooth" });
      }
    });
  });
</script>
