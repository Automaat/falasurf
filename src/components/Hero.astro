---
interface Props {
  title: string;
  subtitle: string;
  images: string[];
  ctaText: string;
  ctaHref: string;
}

const { title, subtitle, images, ctaText, ctaHref } = Astro.props;
const slideCount = images.length;
---

<section class="relative h-screen overflow-hidden" aria-roledescription="slideshow" aria-label="Slideshow">
  {/* Slideshow background */}
  <div class="absolute inset-0">
    {images.map((img, i) => (
      <img
        class="hero-slide absolute inset-0 w-full h-full object-cover transition-opacity duration-1000"
        src={img}
        alt={i === 0 ? "Fala Wind & Surf School - El Cotillo, Fuerteventura" : ""}
        style={`opacity: ${i === 0 ? 1 : 0}`}
        loading={i === 0 ? "eager" : "lazy"}
        fetchpriority={i === 0 ? "high" : "auto"}
        width="1920"
        height="1080"
        data-index={i}
      />
    ))}
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 via-black/45 to-black/70"></div>
  </div>

  {/* Content */}
  <div class="relative flex flex-col items-center justify-center h-screen px-4 text-center pt-64">
    <h1 class="text-3xl md:text-5xl lg:text-6xl font-bold text-white tracking-tight drop-shadow-lg">
      {title}
    </h1>
    <p class="mt-3 text-lg md:text-2xl text-white/80 font-light tracking-wide drop-shadow-md">
      {subtitle}
    </p>
    <a
      href={ctaHref}
      class="mt-8 inline-block bg-navy px-8 py-4 rounded-xl text-white font-semibold text-lg tracking-wide hover:bg-navy-light hover:scale-105 hover:shadow-xl transition-all duration-200"
    >
      {ctaText}
    </a>
  </div>

  {/* Wave bottom edge */}
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto block">
      <path d="M0 80V40C240 80 480 0 720 20C960 40 1200 80 1440 40V80H0Z" fill="white" />
    </svg>
  </div>
</section>

<script define:vars={{ slideCount }}>
  let current = 0;
  let intervalId = null;
  const slides = document.querySelectorAll(".hero-slide");

  function startSlideshow() {
    if (intervalId || slides.length <= 1) return;
    intervalId = setInterval(() => {
      const prev = current;
      current = (current + 1) % slideCount;
      slides[prev].style.opacity = "0";
      slides[current].style.opacity = "1";
    }, 4000);
  }

  function stopSlideshow() {
    if (intervalId) {
      clearInterval(intervalId);
      intervalId = null;
    }
  }

  const mq = window.matchMedia("(prefers-reduced-motion: reduce)");
  if (!mq.matches) startSlideshow();
  mq.addEventListener("change", () => mq.matches ? stopSlideshow() : startSlideshow());
</script>
